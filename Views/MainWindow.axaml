<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UotanInstaller.App.ViewModels"
        xmlns:models="using:UotanInstaller.App.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
        x:Class="UotanInstaller.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="avares://UotanInstaller.App/Assets/uotan.ico"
        Title="{Binding AppTitle}"
        Width="700" Height="450"
        WindowStartupLocation="CenterScreen"
        MinWidth="600" MinHeight="400"
        Background="{DynamicResource SurfaceBrush}">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

    <Grid ColumnDefinitions="180,*"
          RowDefinitions="*,Auto"
          Margin="0">

      <!-- Left Panel: Logo + Version -->
      <StackPanel Grid.Column="0"
                  Grid.Row="0"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Margin="16,16,16,16">

        <Image Source="avares://UotanInstaller.App/Assets/uotan.png"
               Width="120" Height="120"
               Stretch="Uniform"
               Margin="0,0,0,16" />

        <TextBlock Text="UotanToolbox"
                   FontSize="16"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource TextPrimaryBrush}" />

        <TextBlock Text="{Binding VersionText}"
                   Classes="version"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Right Panel: Step Content -->
      <Grid Grid.Column="1" Grid.Row="0"
            RowDefinitions="Auto,*"
            Margin="0,16,24,16">

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12"
                    IsVisible="{Binding IsStepProgressVisible}">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource BrandBrush}"
                    IsVisible="{Binding IsEulaStep}">
              <TextBlock Text="1" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SuccessBrush}"
                    IsVisible="{Binding IsStep1Completed}">
              <TextBlock Text="✓" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding StepConfigText}" VerticalAlignment="Center" FontSize="12" Margin="4,0,8,0" />
          </StackPanel>

          <TextBlock Text="→" VerticalAlignment="Center" Foreground="{DynamicResource TextDisabledBrush}" FontSize="12" />

          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource BrandBrush}"
                    IsVisible="{Binding IsChooseMirrorStep}">
              <TextBlock Text="2" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SuccessBrush}"
                    IsVisible="{Binding IsStep2Completed}">
              <TextBlock Text="✓" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    IsVisible="{Binding IsStep2NotReached}">
              <TextBlock Text="2" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding StepDownloadText}" VerticalAlignment="Center" FontSize="12" Margin="4,0,8,0" />
          </StackPanel>

          <TextBlock Text="→" VerticalAlignment="Center" Foreground="{DynamicResource TextDisabledBrush}" FontSize="12" />

          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource BrandBrush}"
                    IsVisible="{Binding IsInstallingStep}">
              <TextBlock Text="3" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SuccessBrush}"
                    IsVisible="{Binding IsStep3Completed}">
              <TextBlock Text="✓" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    IsVisible="{Binding IsStep3NotReached}">
              <TextBlock Text="3" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding StepInstallText}" VerticalAlignment="Center" FontSize="12" Margin="4,0,8,0" />
          </StackPanel>

          <TextBlock Text="→" VerticalAlignment="Center" Foreground="{DynamicResource TextDisabledBrush}" FontSize="12" />

          <StackPanel Orientation="Horizontal" Spacing="4">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource BrandBrush}"
                    IsVisible="{Binding IsFinishStep}">
              <TextBlock Text="4" FontSize="11" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SurfaceVariantBrush}"
                    IsVisible="{Binding IsStep4NotReached}">
              <TextBlock Text="4" FontSize="11" Foreground="{DynamicResource TextDisabledBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding StepCompleteText}" VerticalAlignment="Center" FontSize="12" Margin="4,0,8,0" />
          </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">

        <!-- Step 1: Eula -->
        <ScrollViewer IsVisible="{Binding IsEulaStep}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Top" Margin="0,16,0,0">
          <TextBlock Text="{Binding EulaTitle}"
                     Classes="step-title" />
          <TextBlock Text="{Binding EulaDesc}"
                     Classes="step-desc" />

          <CheckBox Classes="check"
                    IsChecked="{Binding IsCreateShortcut}"
                    Content="{Binding CreateShortcutText}"
                    Margin="0,8,0,4" />

          <TextBlock Text="{Binding InstallPathText}"
                     Classes="form-label"
                     Margin="0,12,0,4" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Classes="input"
                     Text="{Binding InstallPath}"
                     IsReadOnly="False"
                     FontSize="12" />
            <Button Grid.Column="1"
                    Classes="secondary"
                    Content="{Binding BrowseText}"
                    Command="{Binding BrowseInstallPathCommand}"
                    Margin="8,0,0,0"
                    Padding="12,8" />
          </Grid>

          <CheckBox Classes="check"
                    IsChecked="{Binding IsAgreeEula}"
                    Content="{Binding AgreeEulaText}"
                    Margin="0,4,0,8" />

          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <TextBlock Text="{Binding ChannelLabelText}" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding AvailableChannels}"
                      SelectedItem="{Binding SelectedChannel}"
                      DisplayMemberBinding="{Binding DisplayName}"
                      MinWidth="200" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsChannelWarningVisible}" Margin="0,4,0,0">
            <TextBlock Text="{Binding ChannelWarningText}"
                       Foreground="Orange"
                       TextWrapping="Wrap"
                       FontSize="12" />
          </StackPanel>

          <StackPanel IsVisible="{Binding HasComponents}" Margin="0,8,0,0">
            <TextBlock Text="{Binding ComponentSelectionText}" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ItemsControl ItemsSource="{Binding AvailableComponents}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:ComponentDefinition">
                  <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,2">
                    <CheckBox IsChecked="{Binding IsSelected}" IsEnabled="{Binding !IsRequired}" />
                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Description}" Opacity="0.7" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding TotalInstallSizeText}" Opacity="0.7" FontSize="12" Margin="0,4,0,0" />
          </StackPanel>

          <CheckBox Classes="check"
                    IsChecked="{Binding UseDeltaUpdate}"
                    IsVisible="{Binding IsUpdate}"
                    Margin="0,4,0,4">
            <StackPanel>
              <TextBlock Text="{Binding DeltaUpdateText}" />
              <TextBlock Text="{Binding DeltaUpdateDescText}" Opacity="0.7" FontSize="12" />
            </StackPanel>
          </CheckBox>

          <StackPanel Classes="button-row">
            <Button Classes="accent"
                    Content="{Binding StartText}"
                    Command="{Binding StartCommand}" />
          </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Step 2: ChooseMirror -->
        <Grid IsVisible="{Binding IsChooseMirrorStep}"
              RowDefinitions="Auto,Auto,*,Auto">

          <StackPanel Grid.Row="0">
            <TextBlock Classes="step-title">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} - v{1}">
                  <Binding Path="ChooseMirrorTitleText" />
                  <Binding Path="PatchVersion" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Text="{Binding ChooseMirrorDescText}"
                       Classes="step-desc" />
          </StackPanel>

          <ProgressBar Grid.Row="1"
                       Classes="install"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsLoadingMirrors}"
                       Margin="0,0,0,8" />

          <ListBox Grid.Row="2"
                   ItemsSource="{Binding Mirrors}"
                   SelectedItem="{Binding SelectedMirror}"
                   Margin="0,0,0,8">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="CornerRadius" Value="6" />
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:GenericPatchPackageMirror">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Text="{Binding DisplayUrl}"
                             FontSize="13"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             FontSize="13">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0:F1} MB/s">
                        <Binding Path="Speed" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <StackPanel Grid.Row="3" Classes="button-row">
            <Button Classes="secondary"
                    Content="{Binding BackText}"
                    Command="{Binding BackToEulaStepCommand}" />
            <Button Classes="secondary"
                    Content="{Binding SpeedTestText}"
                    Command="{Binding SpeedTestCommand}"
                    IsVisible="{Binding !IsSpeedTesting}" />
            <ProgressBar Classes="install"
                         IsIndeterminate="True"
                         Width="80"
                         IsVisible="{Binding IsSpeedTesting}" />
            <Button Classes="accent"
                    Content="{Binding InstallButtonText}"
                    Command="{Binding InstallCommand}" />
          </StackPanel>
        </Grid>

        <!-- Step 3: Installing -->
        <StackPanel IsVisible="{Binding IsInstallingStep}"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding InstallingText}"
                     Classes="step-title" />

          <ItemsControl ItemsSource="{Binding InstallSubSteps}"
                        Margin="0,0,0,16">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:InstallSubStepItem">
                <Grid ColumnDefinitions="24,*"
                      Margin="0,4">
                  <Border Width="18" Height="18"
                          CornerRadius="9"
                          Margin="0,0,6,0"
                          Background="{Binding StatusBrush}">
                    <TextBlock Text="{Binding StatusIcon}"
                               FontSize="9"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="{Binding DisplayName}"
                             VerticalAlignment="Center"
                             FontSize="14"
                             Foreground="{Binding StatusForeground}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <ProgressBar Classes="install"
                         Value="{Binding InstallProgressValue}"
                         Maximum="1" />
            <TextBlock Grid.Column="1"
                       Text="{Binding InstallProgressText}"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Width="40"
                       TextAlignment="Right" />
          </Grid>

          <TextBlock Text="{Binding InstallStatusText}"
                     FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" />

          <StackPanel IsVisible="{Binding !IsInstallFailed}"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="0,8,0,0">
            <Button Classes="secondary"
                    Content="{Binding CancelText}"
                    Command="{Binding CancelInstallCommand}"
                    Padding="16,8" />
          </StackPanel>

          <StackPanel IsVisible="{Binding IsInstallFailed}"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Margin="0,8,0,0">
            <Button Classes="secondary"
                    Content="{Binding BackText}"
                    Command="{Binding BackToMirrorStepCommand}"
                    Padding="16,8" />
            <Button Classes="secondary"
                    Content="{Binding RetryText}"
                    Command="{Binding RetryCommand}"
                    Padding="16,8" />
          </StackPanel>
        </StackPanel>

        <!-- Step 4: Finish -->
        <StackPanel IsVisible="{Binding IsFinishStep}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
          <Border Width="64" Height="64"
                  CornerRadius="32"
                  Background="{DynamicResource SuccessBrush}"
                  Margin="0,0,0,16">
            <TextBlock Text="✓"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>

          <TextBlock Text="{Binding InstallCompleteText}"
                     Classes="step-title"
                     HorizontalAlignment="Center" />

          <TextBlock Text="{Binding InstallCompleteDescText}"
                     Classes="step-desc"
                     HorizontalAlignment="Center" />

          <StackPanel Classes="button-row"
                      HorizontalAlignment="Center">
            <Button Classes="secondary"
                    Content="{Binding OpenInstallDirText}"
                    Command="{Binding OpenInstallDirectoryCommand}" />
            <Button Classes="accent"
                    Content="{Binding LaunchAppText}"
                    Command="{Binding LaunchAppCommand}" />
          </StackPanel>
        </StackPanel>

        <!-- Step 5: AlreadyInstalled -->
        <StackPanel IsVisible="{Binding IsAlreadyInstalledStep}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
          <Border Width="64" Height="64"
                  CornerRadius="32"
                  Background="{DynamicResource BrandBrush}"
                  Margin="0,0,0,16">
            <TextBlock Text="✓"
                       FontSize="28"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>

          <TextBlock Classes="step-title"
                     HorizontalAlignment="Center">
            <TextBlock.Text>
              <MultiBinding StringFormat="{}{0} - v{1}">
                <Binding Path="AlreadyInstalledText" />
                <Binding Path="InstalledVersion" />
              </MultiBinding>
            </TextBlock.Text>
          </TextBlock>

          <TextBlock Text="{Binding AlreadyInstalledDescText}"
                     Classes="step-desc"
                     HorizontalAlignment="Center" />

          <StackPanel HorizontalAlignment="Center" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,8">
              <Button Classes="accent"
                      Content="{Binding LaunchAppText}"
                      Command="{Binding LaunchAppCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
              <Button Classes="secondary"
                      Content="{Binding ReinstallText}"
                      Command="{Binding ReinstallCommand}" />
              <Button Classes="secondary"
                      Content="{Binding RollbackText}"
                      Command="{Binding RollbackCommand}"
                      IsVisible="{Binding CanRollback}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        </Grid>

      </Grid>

    </Grid>
</Window>
