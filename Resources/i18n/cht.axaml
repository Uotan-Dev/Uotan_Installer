<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=System.Runtime">
  <s:String x:Key="AppTitle">柚壇工具箱部署器</s:String>
  <s:String x:Key="EulaTitle">使用者授權合約</s:String>
  <s:String x:Key="EulaDesc">請閱讀並同意使用者授權合約後繼續安裝。</s:String>
  <s:String x:Key="CreateShortcut">建立桌面捷徑</s:String>
  <s:String x:Key="AgreeEula">我已閱讀並同意使用者授權合約</s:String>
  <s:String x:Key="InstallPath">安裝路徑</s:String>
  <s:String x:Key="Browse">瀏覽</s:String>
  <s:String x:Key="Start">開始</s:String>
  <s:String x:Key="ChooseMirrorTitle">選擇鏡像源</s:String>
  <s:String x:Key="ChooseMirrorDesc">請選擇一個下載鏡像源，推薦選擇速度最快的鏡像。</s:String>
  <s:String x:Key="SpeedTest">測速</s:String>
  <s:String x:Key="Install">安裝</s:String>
  <s:String x:Key="Installing">正在安裝</s:String>
  <s:String x:Key="Downloading">正在下載安裝包...</s:String>
  <s:String x:Key="Verifying">正在校驗檔案完整性...</s:String>
  <s:String x:Key="Extracting">正在解壓檔案...</s:String>
  <s:String x:Key="InstallComplete">安裝完成</s:String>
  <s:String x:Key="InstallCompleteDesc">UotanToolbox 已成功安裝到您的裝置上。</s:String>
  <s:String x:Key="LaunchApp">啟動柚壇工具箱</s:String>
  <s:String x:Key="AlreadyInstalled">已安裝</s:String>
  <s:String x:Key="AlreadyInstalledDesc">UotanToolbox 已安裝在您的裝置上。</s:String>
  <s:String x:Key="Reinstall">重新安裝</s:String>
  <s:String x:Key="ConfirmExit">確定要退出安裝嗎？</s:String>
  <s:String x:Key="ConfirmExitInstalling">安裝尚未完成，確定要退出安裝嗎？</s:String>
  <s:String x:Key="Yes">是</s:String>
  <s:String x:Key="No">否</s:String>
  <s:String x:Key="Ok">確定</s:String>
  <s:String x:Key="Cancel">取消</s:String>
  <s:String x:Key="LoadMirrorFailed">載入鏡像列表失敗</s:String>
  <s:String x:Key="SpeedTesting">正在測速...</s:String>
  <s:String x:Key="MirrorSpeedUnit">MB/s</s:String>
  <s:String x:Key="Unreachable">不可用</s:String>
  <s:String x:Key="Step_Download">下載安裝包</s:String>
  <s:String x:Key="Step_Verify">校驗檔案完整性</s:String>
  <s:String x:Key="Step_Extract">安裝應用</s:String>
  <s:String x:Key="Step_CreateShortcut">建立捷徑</s:String>
  <s:String x:Key="Step_Launch">啟動應用</s:String>
  <s:String x:Key="Step_DownloadComplete">下載完成</s:String>
  <s:String x:Key="Step_VerifyComplete">校驗通過</s:String>
  <s:String x:Key="Step_ExtractComplete">安裝完成</s:String>
  <s:String x:Key="Step_ShortcutComplete">捷徑建立成功</s:String>
  <s:String x:Key="Step_LaunchComplete">應用已啟動</s:String>
  <s:String x:Key="Step_VerifyRunning">正在校驗檔案完整性...</s:String>
  <s:String x:Key="Step_ExtractPrepare">正在準備解壓...</s:String>
  <s:String x:Key="Step_ExtractRunning">正在安裝...</s:String>
  <s:String x:Key="Step_ShortcutRunning">正在建立捷徑...</s:String>
  <s:String x:Key="Step_LaunchRunning">正在啟動應用...</s:String>
  <s:String x:Key="Step_Downloading">正在下載...</s:String>
  <s:String x:Key="Step_Skipped">已跳過</s:String>
  <s:String x:Key="Step_Executing">正在執行:</s:String>
  <s:String x:Key="Step_Completed">完成</s:String>
  <s:String x:Key="VersionUnavailable">取得失敗</s:String>
  <s:String x:Key="Retry">重試</s:String>
  <s:String x:Key="OpenInstallDir">開啟安裝目錄</s:String>
  <s:String x:Key="InstallFailed">安裝失敗</s:String>
  <s:String x:Key="InstallCancelled">安裝已取消</s:String>
  <s:String x:Key="PrepareInstall">準備安裝...</s:String>
  <s:String x:Key="Update">更新</s:String>
  <s:String x:Key="LaunchFailed">應用啟動失敗</s:String>
  <s:String x:Key="DiskSpaceInsufficient">磁碟空間不足</s:String>
  <s:String x:Key="SystemVersionInsufficient">系統版本不符合需求</s:String>
  <s:String x:Key="PlatformCheckFailed">平台檢查未通過</s:String>
</ResourceDictionary>