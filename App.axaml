<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UotanInstaller.App.App"
             xmlns:local="using:UotanInstaller.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://UotanInstaller.App/Styles/FluentStyles.axaml" />
    </Application.Styles>
</Application>
